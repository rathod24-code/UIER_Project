model.eval()
total_psnr = 0
count = 0

with torch.no_grad():
    for raw, ref in val_loader:
        raw = raw.to(device)
        output = model(raw)

        for i in range(output.shape[0]):
            out_np = output[i].cpu().permute(1,2,0).numpy()
            ref_np = ref[i].permute(1,2,0).numpy()
            total_psnr += psnr(ref_np, out_np, data_range=1.0)
            count += 1

avg_psnr = total_psnr / count
print(f"✅ Average PSNR: {avg_psnr:.2f} dB")
